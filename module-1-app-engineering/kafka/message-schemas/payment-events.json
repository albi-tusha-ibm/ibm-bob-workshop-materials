{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PaymentEvent",
  "type": "object",
  "required": ["eventType", "paymentId", "orderId", "correlationId"],
  "properties": {
    "eventType": {
      "type": "string",
      "enum": ["payment-initiated", "payment-completed", "payment-failed"]
    },
    "paymentId": {
      "type": "string",
      "format": "uuid"
    },
    "orderId": {
      "type": "string",
      "format": "uuid"
    },
    "amount": {
      "type": "number"
    },
    "status": {
      "type": "string"
    },
    "correlationId": {
      "type": "string"
    }
  }
}
